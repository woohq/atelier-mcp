{
  "name": "atelier-mcp",
  "version": "0.1.0",
  "description": "MCP server for programmatic game art creation",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "atelier-mcp": "dist/server/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "concurrently \"vite preview/\" \"node --watch dist/server/index.js\"",
    "preview": "vite preview/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "check": "tsc --noEmit && eslint src/ tests/ && vitest run",
    "start": "node dist/server/index.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "playwright": "^1.58.2",
    "three": "^0.183.2",
    "three-bvh-csg": "^0.0.18",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^22.0.0",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^3.2.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "prettier": "^3.8.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.0"
  }
}
